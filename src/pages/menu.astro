---
import { Picture } from "astro:assets";
import Layout from "@/layouts/Layout.astro";
import { BaseWPSchema } from "@/types";
import ProductsMenu from "@/components/menu/PorudctsMenu.astro";
const url = `${import.meta.env.API_URL}/pages?slug=menu`;
const response = await fetch(url);
const json = await response.json();
const data = BaseWPSchema.parse(json[0]);
---

<Layout
    title="Nosotros"
    subtitle={data.acf.subtitulo}
    bgImage={data.featured_images.full.url}
>
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-10">
        <Picture
            src={data.featured_images.medium_large.url}
            alt={`Imagen de ${data.title.rendered}`}
            width={data.featured_images.medium_large.width}
            height={data.featured_images.medium_large.height}
            formats={["webp", "avif"]}
            widths={[480, 768, 1024]}
        />

        <div
            class="text-xl space-y-3 mt-10 lg:mt-0 text-justify"
            set:html={data.content.rendered}
        />
    </div>

    <ProductsMenu slot="after-main-content" />
</Layout>
